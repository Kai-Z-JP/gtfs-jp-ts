{
  "name": "gtfs-jp-ts",
  "private": true,
  "type": "module",
  "version": "4.0.0-beta.4",
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "sync-versions": "node scripts/sync-versions.mjs",
    "build": "pnpm -r --filter \"@gtfs-jp/*\" build",
    "typecheck": "pnpm -r --filter \"@gtfs-jp/*\" typecheck",
    "test": "pnpm --filter \"@gtfs-jp/types\" test && pnpm --filter \"@gtfs-jp/loader\" test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  }
}
