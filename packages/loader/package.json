{
  "name": "@gtfs-jp/loader",
  "version": "4.0.0-beta.9",
  "description": "Browser SQLite WASM loader for GTFS-JP v4 data (in-memory / OPFS)",
  "type": "module",
  "license": "MIT",
  "author": "Kai-Z-JP",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kai-Z-JP/gtfs-jp-ts.git",
    "directory": "packages/loader"
  },
  "homepage": "https://github.com/Kai-Z-JP/gtfs-jp-ts/tree/main/packages/loader",
  "keywords": [
    "gtfs",
    "gtfs-jp",
    "sqlite",
    "wasm",
    "opfs",
    "browser",
    "loader",
    "transit",
    "japan"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./kysely": {
      "types": "./dist/kysely.d.ts",
      "import": "./dist/kysely.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:deps": "pnpm --filter @gtfs-jp/types build",
    "build": "pnpm build:deps && tsup --config tsup.config.ts",
    "typecheck": "pnpm build:deps && tsc -p tsconfig.json --noEmit",
    "test": "pnpm build:deps && vitest run"
  },
  "dependencies": {
    "@gtfs-jp/types": "workspace:*",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build6",
    "kysely": "^0.28.14"
  },
  "peerDependencies": {
    "kysely": "^0.28.14"
  },
  "devDependencies": {
    "jszip": "^3.10.1",
    "rollup": "^4.60.0",
    "tsup": "^8.5.0",
    "udsv": "^0.7.3",
    "vite": "^6.0.0"
  }
}
