{
  "name": "@gtfs-jp/loader",
  "version": "4.0.0-beta.3",
  "description": "Browser SQLite WASM loader for GTFS-JP v4 data (in-memory / OPFS)",
  "type": "module",
  "license": "MIT",
  "author": "Kai-Z-JP",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kai-Z-JP/gtfs-jp-ts.git",
    "directory": "packages/loader"
  },
  "homepage": "https://github.com/Kai-Z-JP/gtfs-jp-ts/tree/main/packages/loader",
  "keywords": [
    "gtfs",
    "gtfs-jp",
    "sqlite",
    "wasm",
    "opfs",
    "browser",
    "loader",
    "transit",
    "japan"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@gtfs-jp/types": "workspace:*",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build6"
  },
  "devDependencies": {
    "jszip": "^3.10.1",
    "tsup": "^8.5.0",
    "udsv": "^0.7.3"
  }
}
